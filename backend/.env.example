# Copy to .env and fill in real values. .env is gitignored; never commit secrets.

# Bing / Microsoft AI Search.
BING_SEARCH_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
BING_NEWS_ENDPOINT=https://api.microsoft.ai/v3/search/news
BING_FINANCE_ENDPOINT=https://api.microsoft.ai/v3/search/finance
BING_PLACES_ENDPOINT=https://api.microsoft.ai/v3/search/places

# Azure AI Foundry (OpenAI-compatible /openai/v1 surface), wired in Week 2.
# base_url is the /openai/v1 root (no trailing /responses). The deployed models
# are served via the Responses API, so llm.py uses client.responses.parse.
# The *_MODEL values are Foundry deployment names, not bare model IDs.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://<your-resource>.services.ai.azure.com/openai/v1
OPENAI_PLANNER_MODEL=gpt-5.4-pro
OPENAI_SYNTH_MODEL=gpt-5.4-mini
